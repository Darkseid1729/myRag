APP_HOST=127.0.0.1
APP_PORT=8000

# Optional LLM provider (ollama | llamacpp | openai | none)
LLM_PROVIDER=none
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

OPENAI_API_KEY=

# Memory limits
SQLITE_PAGE_CACHE_KB=4096
VECTOR_LRU_CACHE_KB=1024

# Embedding model (auto-downloaded on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2
MODELS_DIR=./models

# Data storage
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
